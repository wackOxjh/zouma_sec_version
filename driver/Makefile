# 统一使用内核路径
KDIR?=/home/linux/Desktop/linux-4.19-loongson-embeded

# 获取所有子目录
SUBDIRS := $(shell find . -maxdepth 1 -type d ! -name "." ! -name ".." ! -name ".*" | sort)

# 编译所有子模块
all:
	@echo "\033[32m=====================================================================================================\n\033[0m"
	@echo "\033[32m统一使用内核路径: $(KDIR)\n\033[0m"
	@echo "\033[32m=====================================================================================================\n\033[0m"
	@for dir in $(SUBDIRS); do \
		if [ -f $$dir/Makefile ]; then \
			echo "\033[32m=====================================================================================================\033[0m";\
			echo "\033[32m🔨 开始编译目录: $$dir\033[0m";\
			cd $$dir && make KDIR=$(KDIR) || exit 1; \
			cd - >/dev/null; \
			echo ""; \
		fi; \
	done
	@echo "✅ \033[32m所有子模块编译完成\033[0m"

# 清理所有子模块
clean:
	@echo "\033[32m=====================================================================================================\n\033[0m"
	@echo "🔨 \033[32m开始清理所有子模块...\033[0m"
	@echo "\033[32m=====================================================================================================\n\033[0m"
	@for dir in $(SUBDIRS); do \
		if [ -f $$dir/Makefile ]; then \
			echo "\033[32m=====================================================================================================\033[0m";\
			echo "\033[32m🔨 开始清理目录: $$dir\033[0m";\
			cd $$dir && make KDIR=$(KDIR) clean; \
			cd - >/dev/null; \
			echo ""; \
		fi; \
	done
	@echo "✅ \033[32m所有子模块清理完成\033[0m"

.PHONY: all clean
